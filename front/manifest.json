{
  "manifest_version": 3,
  "name": "Password Manager",
  "version": "1.0.0",
  "description": "A secure password manager Chrome extension",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["tabs", "scripting", "activeTab"],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/autofill.js"],
      "css": ["src/content/inPageNotificatio.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' http://localhost:5173; object-src 'self'"
  },
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ]
}